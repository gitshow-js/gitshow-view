# GitShow View server configuration.
# Copy to .env and fill in real values. Never commit .env.

# --- GitHub OAuth App credentials ---
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# OAuth scope to request. "repo" grants read/write to public and private repos.
GITHUB_OAUTH_SCOPE=repo

# --- Session encryption ---
# 32-byte key (base64) for AES-256-GCM encryption of the session/state cookies.
# Generate with:  openssl rand -base64 32
SESSION_KEY=

# --- Deployment ---
# Public origin where the app is served. Used to build the OAuth redirect_uri
# and to decide whether cookies get the Secure flag (https -> Secure).
# The GitHub OAuth App's "Authorization callback URL" must be
# <PUBLIC_BASE_URL>/auth/callback
PUBLIC_BASE_URL=https://gitshow.net

# Internal HTTP port the server listens on (behind your TLS-terminating proxy).
PORT=8084
